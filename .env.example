# Copia in .env e adatta per Docker Compose locale.
COMPOSE_PROJECT_NAME=payment-gateway

POSTGRES_DB=payments
POSTGRES_USER=payments_user
POSTGRES_PASSWORD=payments_pass

# Usata dal BFF payment-ui (nginx) e dal proxy Vite in dev — mai inclusa nel bundle JS.
PAYMENT_API_KEY=pgw-demo-key-32chars-minimum!!
